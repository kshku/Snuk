var Point = type { // type definition
    var x: int
    var y: int
}

type Square { // type definition syntax sugar
    fn area() {
        self.width * height
    }

    var top_left: Point
    var width: int
    var height: int
    
}

var x: Point = Point
type int y = {value: 100}

// type instance
var square: Square = type Square {top_left: type Point {x: 10; y: 20;}; width: 20; height: 20}

// Type annotation
var square2: Square = type Square {
    top_left: type Point {
        x: 10
        y: 20
    }
    width: 20
    height: 20
}

// Type instance with syntax sugar (s2 and s3 are variables)
type Square s2{width: 10; height: 10}
type Square s3 = {width: 10; height: 10}

print square.top_left.x
square.top_left.x = 20
print square.top_left.x

print square.area()

if Square.width == null {
    print "Hurray!"
} else {
    print "Noooo!"
}

// calling method with self on the type (not instance) will cause error
// Square.area()

fn make_type(color, use_self: bool = false) {
    if (use_self) {
        type {
            var color = color
            fn to_string() {
                self.color
                // self.square.area() // Accessing outside scope, throws error
            }
        }
    } else {
        type {
            var color = color
            fn to_string() {
                color
            }
        }
    }
}

var RedThing = make_type("Red")
print RedThing.color
print RedThing.to_string()
print type RedThing{}.to_string() // works fine using type inst
var BlueThing = make_type("Blue", use_self = true)
// print BlueThing.to_string() // cannot call without instance since it uses self, will get self error
print type BlueThing{}.to_string() // works

print make_type("Green").to_string()

print Point
print Square
print RedThing
print BlueThing

print square
print s2
