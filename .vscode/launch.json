{
    "version": "0.2.0",
    "configurations": [
        // Engine
        {
            "name": "(Linux) Engine",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/testapp/testapp",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/testapp",
            "environment": []
        },
        {
            "name": "(Windows) Engine",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\build\\testapp\\testapp.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}\\build\\testapp",
            "environment": [
                {
                    "name": "PATH",
                    "value": "..\\engine;${env:PATH}"
                }
            ],
            "console": "integratedTerminal"
        },
